[Desktop Action SshLxd]
Name=ssh LXD
Exec=xfce4-terminal --tab --title=LXD -x ssh-lxd
" >> ${pth}/${name}.desktop
	fi
else
	_echoe "${name} are skipped"
	_echoe "${file} file not found"
fi

