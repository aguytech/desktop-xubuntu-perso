#!/bin/bash

# xprop WM_CLASS
########################  MAIN

pth=~/.local/share/applications
[ -d "${pth}" ] || mkdir -p ${pth}

_echot "------- xfce-settings-manager"
name=xfce-settings-manager
file=/usr/share/applications/${name}.desktop
if [ -f ${file} ]; then
	_eval cp --update=all ${file} ${pth}
	if ! grep -q '\[Desktop Action Separator\]' ${pth}/${name}.desktop; then
		menuadd="Separator;ManjaroSettings;XfceSettings;LightdmGtk;Qt6ct;DconfSet;PlankSet;Separator;PamacManager;TaskManager;Gparted;DiskUsage;"
		grep -q '^Actions=' ${pth}/${name}.desktop \
			&& sed -i "s|^\(Actions=.*\)$|\1${menuadd}|" ${pth}/${name}.desktop \
			|| echo "Actions=${menuadd}" >> ${pth}/${name}.desktop
		echo "
[Desktop Action Separator]
Name=−−−−−−−−−−
Exec=

[Desktop Action PamacManager]
Name=Pamac Manager
Exec=pamac-manager

[Desktop Action XfceSettings]
Name=xfce4 settings
Exec=xfce4-settings-editor

[Desktop Action TaskManager]
Name=Task manager
Exec=xfce4-taskmanager

[Desktop Action LightdmGtk]
Name=lightdm Gtk greeter settings
Exec=lightdm-gtk-greeter-settings-pkexec

[Desktop Action Qt6ct]
Name=QT6 settings
Exec=qt6ct

[Desktop Action DiskUsage]
Name=Disk Usage
Exec=baobab

[Desktop Action Gparted]
Name=Gparted
Exec=gksudo gparted

[Desktop Action DconfSet]
Name=Dconf settings
Exec=dconf-editor

[Desktop Action ManjaroSettings]
Name=Manjaro settings
Exec=manjaro-settings-manager
" >> ${pth}/${name}.desktop
	fi
else
	_echoe "${name} are skipped"
	_echoe "${file} file not found"
fi

_echot "------- thunar"
name=thunar
file=/usr/share/applications/${name}.desktop
if [ -f ${file} ]; then
	_eval cp --update=all ${file} ${pth}
	if ! grep -q '\[Desktop Action Separator\]' ${pth}/${name}.desktop; then
		menuadd="ThunarNode1;Separator;Terminal;SshDev;SshS;SshNode1;SshLxd;"
		grep -q '^Actions=' ${pth}/${name}.desktop \
			&& sed -i "s|^\(Actions=.*\)$|\1${menuadd}|" ${pth}/${name}.desktop \
			|| echo "Actions=${menuadd}" >> ${pth}/${name}.desktop
		echo "
[Desktop Action Separator]
Name=−−−−−−−−−−
Exec=

[Desktop Action ThunarNode1]
Name=Thunar node1
Exec=thunar_newtabs /usr/local/bs sftp://root@node1/

[Desktop Action Terminal]
Name=Terminal
Exec=xfce4-terminal

